# ═══════════════════════════════════════════════════════════════
#  ClawScholar — Environment Variables
#  Copy to .env and fill in your values.
#
#  KEY STORY (short answer to "which key do I need?"):
#
#  1) OPENAI_API_KEY — required (powers all agent LLM calls)
#  2) EMBEDDINGS_API_KEY — optional (vector embeddings for RAG; if unset we fall back to BM25-only)
# ═══════════════════════════════════════════════════════════════

# ─── Primary LLM: OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# ─── Embeddings (optional) ─────────────────────────────────────────────
# Leave blank to disable vector embeddings (BM25 search still works).
EMBEDDINGS_BASE_URL=
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small

# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=clawscholar
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=clawscholar
DATABASE_URL=postgresql+asyncpg://clawscholar:change-me-in-production@postgres:5432/clawscholar

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET_KEY=generate-a-secure-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# ─── Sandbox ─────────────────────────────────────────────────
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MAX_MEMORY_MB=512

# ─── Storage ─────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=json
